<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <!-- internal css -->
     <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        .container{
            background-color: #66ccff;
            border: 1px solid black;
            width: 100vw;
            height: 100vh;
        }
        .box{
            background-color: brown;
            border:black 1px solid;
            width: 350px;
            height: 80px;
            border-radius: 15px;
            margin: 10px;
            animation-name: leftrectangle;
            position: relative;
            animation-duration: 5s;
            animation-iteration-count: infinite;
            animation-delay: 1s;
            animation-timing-function:linear;
            animation-direction: alternate;
        }
        @keyframes leftrectangle{
            from{
                top:0;
                left:0;
            }
            to{
                top:0;
                left: 1300px;
            }

        }
         #box2{
            background-color: brown;
            border:black 1px solid;
            width: 350px;
            height: 80px;
            border-radius: 15px;
            margin: 10px;
            animation-name: rightrectangle;
            position: relative;
            animation-duration: 5s;
            animation-iteration-count: infinite;
            animation-delay: 1s;
            animation-timing-function:ease-in;
            animation-direction: alternate;
        }
       
       @keyframes rightrectangle{

    from{
        top:500px;
        left:1300px;
    }

    to{
        top:500px;
        left:0px;
    }
}
       
#circle{
            background-color: blue;
            border:black 1px solid;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            margin: 10px;
            animation-name:circle;
            position: relative;
            animation-duration: 10s;
            animation-iteration-count: infinite;
            animation-delay: 0s;
            animation-timing-function:ease-in-out;
            animation-direction: alternate;
            top: 30%;
            left: 670px;
        }
        @keyframes circle{
            0%{
                top: 1%;
                left: 5%;
            }
            30%{
                top: 5%; 
                 left: 90%;
            }
            60%{
                top: 60%;
                left: 10%;
         }
            100%{
                top: 75%;
                left: 90%;
            }
        }
     </style>
</head>
<body>
    <div class="container">
        <div class="box"></div>
        <div id="circle" class="box"></div>
        <div  id="box2" class="box"></div>
    </div>
</body>
</html>
